module apb_slave_mem #(
    parameter ADDR_WIDTH = 32,
    parameter DATA_WIDTH = 32,
    parameter MEM_DEPTH = 256
)(
    input clk,
    input rst_n,

    input [ADDR_WIDTH-1:0] PADDR,
    input PSEL,
    input PENABLE,
    input PWRITE,
    input [DATA_WIDTH-1:0] PWDATA,

    output [DATA_WIDTH-1:0] PRDATA,
    output PREADY,

    output [DATA_WIDTH-1:0] rd_data_o,
    output rd_valid_o
);

function integer clog2;
    input integer value;
    begin
        value = value - 1;
        for (clog2 = 0; value > 0; clog2 = clog2 + 1)
            value = value >> 1;
    end
endfunction

localparam ADDR_BITS = clog2(MEM_DEPTH);

reg [DATA_WIDTH-1:0] mem [MEM_DEPTH-1:0];
wire active = PSEL && PENABLE;

always @(posedge clk)
    if (active && PWRITE && PREADY)
        mem[PADDR[ADDR_BITS-1:0]] <= PWDATA;

assign PRDATA = mem[PADDR[ADDR_BITS-1:0]];

reg ready_reg;
always @(posedge clk or negedge rst_n)
    if (!rst_n) ready_reg <= 0;
    else ready_reg <= active;

assign PREADY = ready_reg;

assign rd_data_o  = PRDATA;
assign rd_valid_o = active && !PWRITE && PREADY;

endmodule
